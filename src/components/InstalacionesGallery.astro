---
import type { Gallery } from '@/types';
import { Image } from 'astro:assets';

interface Props {
	gallery: Gallery[];
}

const { gallery } = Astro.props;
---

<section id="instalaciones" class="overflow-hidden">
	<div class="instalaciones-header bg-gris py-20">
		<div class="max-w-7xl mx-auto px-6 text-center">
			<span
				class="instalaciones-eyebrow inline-block font-display font-semibold text-dorado
               text-sm uppercase tracking-[0.2em] mb-3"
			>
				Conoce nuestro espacio
			</span>
			<h2
				class="instalaciones-h2 font-display font-extrabold text-azul
               text-4xl md:text-5xl lg:text-6xl leading-tight mb-4"
			>
				Nuestras Instalaciones
			</h2>
			<div
				class="instalaciones-divider flex items-center justify-center gap-3 mb-5"
			>
				<span class="h-px w-16 bg-azul/20"></span>
				<span class="w-3 h-3 rounded-full bg-dorado"></span>
				<span class="h-px w-16 bg-azul/20"></span>
			</div>
			<p
				class="instalaciones-sub font-body text-texto/65 max-w-lg mx-auto text-base leading-relaxed"
			>
				Espacios modernos diseñados para el desarrollo integral, el aprendizaje
				y la convivencia de nuestros alumnos.
			</p>
		</div>
	</div>

	<div id="inst-pin-wrapper" style="height: 100svh; min-height: 560px;">
		{
			gallery.map((f, i) => (
				<div
					class="inst-panel absolute inset-0 overflow-hidden"
					style={`height: 100svh; min-height: 560px; z-index: ${10 + i * 10};`}
					data-panel={i}
				>
					<Image
						src={f.full.url}
						alt={`Imagen instalación - ${i + 1}`}
						width={1600}
						height={1200}
						class="inst-img absolute left-0 w-full object-cover will-change-transform"
						style="height: 130%; top: -15%;"
						data-img={i}
					/>

					<div class="absolute inset-0 bg-linear-to-b from-azul-oscuro/10 via-transparent to-azul-oscuro/25 pointer-events-none" />
				</div>
			))
		}
	</div>
</section>

<style>
	#inst-pin-wrapper {
		position: relative;
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener('astro:page-load', () => {
		const wrapper = document.querySelector(
			'#inst-pin-wrapper',
		) as HTMLElement | null;
		const panels = document.querySelectorAll('.inst-panel');
		const imgs = document.querySelectorAll('.inst-img');
		if (!wrapper || !panels.length) return;

		const n = panels.length;
		const vh = () => window.innerHeight;
		// Total extra scroll distance = (n-1) full viewports
		const scrollDist = (n - 1) * vh();

		// ── Header entrance ───────────────────────────────────────────────
		gsap
			.timeline({
				scrollTrigger: { trigger: '.instalaciones-header', start: 'top 82%' },
			})
			.fromTo(
				'.instalaciones-eyebrow',
				{ opacity: 0, y: 18 },
				{ opacity: 1, y: 0, duration: 0.55, ease: 'power3.out' },
			)
			.fromTo(
				'.instalaciones-h2',
				{ opacity: 0, y: 28 },
				{ opacity: 1, y: 0, duration: 0.65, ease: 'power3.out' },
				'-=0.3',
			)
			.fromTo(
				'.instalaciones-divider',
				{ opacity: 0, scaleX: 0 },
				{ opacity: 1, scaleX: 1, duration: 0.45, ease: 'power2.out' },
				'-=0.35',
			)
			.fromTo(
				'.instalaciones-sub',
				{ opacity: 0, y: 14 },
				{ opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' },
				'-=0.25',
			);

		// ── Initial image states: slightly over-zoomed (Ken Burns start) ──
		imgs.forEach((img, i) => {
			// Panel 0 is always visible; panels 1-3 start hidden below
			if (i === 0) {
				gsap.set(img, { scale: 1.12, y: '0%' });
			} else {
				gsap.set(panels[i], {
					// Slight diagonal variation per panel makes wipes feel organic
					clipPath:
						[
							'polygon(0% 100%, 100% 100%,  100% 100%, 0%   100%)', // straight
							'polygon(0% 100%, 100% 100%,   100% 100%, 0%   100%)', // right leads slightly (96%)
							'polygon(0% 100%,  100% 100%,  100% 100%, 0%   100%)', // left leads slightly
							'polygon(0% 100%, 100% 100%,  100% 100%, 0%   100%)', // straight
						][i] ?? 'polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%)',
				});
				gsap.set(img, { scale: 1.15, y: '4%' }); // starts zoomed + slightly shifted down
			}
		});

		// ── Pin + sequential scrub timeline ───────────────────────────────
		const tl = gsap.timeline({
			scrollTrigger: {
				trigger: wrapper,
				start: 'top top',
				end: `+=${scrollDist}`,
				pin: true,
				scrub: 1.6, // higher = smoother / lazier
				anticipatePin: 1,
			},
		});

		for (let i = 1; i < n; i++) {
			const panel = panels[i];
			const img = imgs[i];
			const prevImg = imgs[i - 1];

			tl
				// Reveal new panel: clip wipes up from bottom
				.to(panel, {
					clipPath: 'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)',
					ease: 'power2.inOut',
					duration: 1,
				})
				// New image zooms from 1.15 → 1.0 while revealing (Ken Burns in)
				.to(
					img,
					{
						scale: 1.0,
						y: '0%',
						ease: 'power2.out',
						duration: 1,
					},
					'<',
				)
				// Previous image gently zooms in as it goes "underneath"
				.to(
					prevImg,
					{
						scale: 1.06,
						ease: 'power1.inOut',
						duration: 1,
					},
					'<',
				);
		}

		// Continuous parallax on panel 0 (the base layer, always behind)
		// — moves at a slower rate than the pin, creating depth
		tl.to(
			imgs[0],
			{
				y: '-10%',
				ease: 'none',
				duration: n - 1, // spans the full scroll distance
			},
			0,
		); // starts from the very beginning of the timeline
	});
</script>
