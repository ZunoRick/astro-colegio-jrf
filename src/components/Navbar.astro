---
import { Image } from 'astro:assets';
import escudo from '@/assets/img/escudo.webp';

const links = [
	{ label: 'Inicio', href: '#' },
	{ label: 'Nosotros', href: '#' },
	{ label: 'Nuestros Servicios', href: '#' },
	{ label: 'Galería', href: '#' },
	{ label: 'Contacto', href: '#' },
];
---

<header
	id="navbar"
	class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-azul-oscuro"
>
	<nav class="mx-auto max-w-7xl px-6 py-3 flex items-center justify-between">
		<!-- Logo -->
		<a href="/" class="flex items-center gap-3 group">
			<div class="relative w-12 h-12 shrink-0">
				<div
					class="absolute inset-0 rounded-full bg-dorado/20 scale-0 group-hover:scale-110 transition-transform duration-300"
				>
				</div>
				<Image
					src={escudo}
					alt="Escudo Colegio JRF"
					width={50}
					height={50}
					class="relative z-10 w-12 h-12 object-contain drop-shadow-md"
				/>
			</div>
			<div class="hidden sm:block leading-tight">
				<p
					class="font-display font-semibold text-white/90 text-xs uppercase tracking-wider"
				>
					Colegio
				</p>
				<p
					class="font-display font-extrabold text-dorado text-base leading-none"
				>
					Jesús Romero Flores
				</p>
			</div>
		</a>

		<!-- Desktop links -->
		<ul class="hidden lg:flex items-center gap-7">
			{
				links.map((l) => (
					<li>
						<a
							href={l.href}
							class="relative font-display font-medium text-sm text-white/80 hover:text-white transition-colors
                   after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-0
                   after:bg-dorado after:transition-all after:duration-300
                   hover:after:w-full"
						>
							{l.label}
						</a>
					</li>
				))
			}
		</ul>

		<!-- CTA + Hamburger -->
		<div class="flex items-center gap-3">
			<a
				href="#contacto"
				class="hidden lg:inline-flex items-center gap-1.5 bg-dorado text-texto font-display font-bold
               text-sm px-5 py-2.5 rounded-full hover:bg-dorado-oscuro transition-colors shadow-md"
			>
				Inscripciones
			</a>

			<button
				id="menu-toggle"
				class="lg:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
				aria-label="Abrir menú"
				aria-expanded="false"
			>
				<svg
					id="icon-open"
					xmlns="http://www.w3.org/2000/svg"
					width="22"
					height="22"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2.5"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M4 6h16M4 12h16M4 18h16"></path>
				</svg>
				<svg
					id="icon-close"
					xmlns="http://www.w3.org/2000/svg"
					width="22"
					height="22"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2.5"
					class="hidden"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
		</div>
	</nav>

	<!-- Mobile menu -->
	<div
		id="mobile-menu"
		class="lg:hidden hidden overflow-hidden"
		style="background: rgba(19,47,97,0.97); backdrop-filter: blur(12px);"
	>
		<ul
			class="max-w-7xl mx-auto px-6 py-5 flex flex-col gap-1 border-t border-white/10"
		>
			{
				links.map((l) => (
					<li>
						<a
							href={l.href}
							class="flex items-center gap-2 text-white/80 hover:text-dorado font-display
                   font-medium py-2.5 border-b border-white/5 last:border-0 transition-colors"
						>
							<span class="w-1.5 h-1.5 rounded-full bg-dorado shrink-0" />
							{l.label}
						</a>
					</li>
				))
			}
			<li class="pt-3">
				<a
					href="#contacto"
					class="flex justify-center bg-dorado text-texto font-display font-bold
                 text-sm px-5 py-3 rounded-full hover:bg-dorado-oscuro transition-colors"
				>
					Inscripciones
				</a>
			</li>
		</ul>
	</div>
</header>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener('astro:page-load', () => {
		const navbar = document.getElementById('navbar');
		const toggle = document.getElementById('menu-toggle');
		const menu = document.getElementById('mobile-menu');
		const iconOpen = document.getElementById('icon-open');
		const iconClose = document.getElementById('icon-close');
		let open = false;

		// Entrance
		gsap.fromTo(
			navbar,
			{ y: -64, opacity: 0 },
			{ y: 0, opacity: 1, duration: 0.7, ease: 'power3.out', delay: 0.2 },
		);

		// Scroll: transparent → solid
		ScrollTrigger.create({
			start: 'top+=80 top',
			onEnter: () => navbar?.classList.add('bg-azul-oscuro', 'shadow-lg'),
			onLeaveBack: () =>
				navbar?.classList.remove('bg-azul-oscuro', 'shadow-lg'),
		});

		// Mobile toggle
		toggle?.addEventListener('click', () => {
			open = !open;
			toggle.setAttribute('aria-expanded', String(open));

			if (open) {
				menu?.classList.remove('hidden');
				iconOpen?.classList.add('hidden');
				iconClose?.classList.remove('hidden');
				gsap.fromTo(
					menu,
					{ height: 0, opacity: 0 },
					{ height: 'auto', opacity: 1, duration: 0.35, ease: 'power2.out' },
				);
			} else {
				iconOpen?.classList.remove('hidden');
				iconClose?.classList.add('hidden');
				gsap.to(menu, {
					height: 0,
					opacity: 0,
					duration: 0.3,
					ease: 'power2.in',
					onComplete: () => {
						menu?.classList.add('hidden');
						gsap.set(menu, { clearProps: 'height,opacity' });
					},
				});
			}
		});

		// Close on link click
		menu?.querySelectorAll('a').forEach((a) =>
			a.addEventListener('click', () => {
				if (!open) return;
				open = false;
				toggle?.setAttribute('aria-expanded', 'false');
				iconOpen?.classList.remove('hidden');
				iconClose?.classList.add('hidden');
				menu.classList.add('hidden');
				gsap.set(menu, { clearProps: 'height,opacity' });
			}),
		);
	});
</script>
